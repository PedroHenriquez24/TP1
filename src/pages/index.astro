  </head>
<!-- HTML -->
  <body>
    <header>
      <h1>Generador de Colores 🎨</h1>
    </header>

    <main>
<section class="card">
  <p>Colores actuales:</p>

  <p id="color1">Color 1: #667eea</p>
  <p id="color2">Color 2: #764ba2</p>
  <div class="button-group">
	<button id="btn-color1">Cambiar Color 1</button>
	<button id="btn-color2">Cambiar Color 2</button>
  </div>
</section>
    </main>

    <footer>
      <p>Proyecto TP1 - Astro</p>
    </footer>
<!-- JavaScript -->
	<script>
  let color1 = "#667eea";
  let color2 = "#764ba2";

  const btn1 = document.getElementById("btn-color1");
  const btn2 = document.getElementById("btn-color2");

  const text1 = document.getElementById("color1");
  const text2 = document.getElementById("color2");

  function generarColor() {
    const letras = "0123456789ABCDEF";
    let color = "#";

    for (let i = 0; i < 6; i++) {
      color += letras[Math.floor(Math.random() * 16)];
    }

    return color;
  }

  function actualizarFondo() {
    document.body.style.background =
      "linear-gradient(135deg, " + color1 + ", " + color2 + ")";
  }

  btn1.addEventListener("click", () => {
    color1 = generarColor();
    text1.textContent = "Color 1: " + color1;
    actualizarFondo();
  });

  btn2.addEventListener("click", () => {
    color2 = generarColor();
    text2.textContent = "Color 2: " + color2;
    actualizarFondo();
  });
</script>
  </body>
</html>