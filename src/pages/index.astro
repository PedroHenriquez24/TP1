<!-- CSS -->
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Generador de Colores</title>

    <style>
body {
  font-family: Arial, sans-serif;
  margin: 0;
  text-align: center;

  min-height: 100vh;
  display: flex;
  flex-direction: column;

  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #333;
}

header {
  background: transparent;
  color: white;
  padding: 3vh;
}

main {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 5vh 5vw;
}

.card {
  background: white;
  padding: 4vh 4vw;
  border-radius: 2vh;

  width: 90%;
  max-width: 400px;

  box-shadow: 0 0.5vh 2vh rgba(0,0,0,0.2);
  transition: transform 0.2s;
}

.card:hover {
  transform: scale(1.03);
}

button {
  padding: 2vh 3vw;
  font-size: 1rem;

  border: none;
  border-radius: 1vh;

  background: linear-gradient(135deg, #00c6ff, #0072ff);
  color: white;

  cursor: pointer;
  transition: transform 0.2s, opacity 0.2s;

  width: 100%;
}

button:hover {
  transform: scale(1.05);
  opacity: 0.9;
}

.button-group {
  display: flex;
  flex-direction: column;
  gap: 2vh;
  margin-top: 3vh;
}

footer {
  padding: 2vh;
  color: rgba(255,255,255,0.7);
  background: transparent;
}
.color-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 1vh 0;
  cursor: pointer;
}

.color-box {
  width: 4vh;
  height: 4vh;
  border-radius: 0.8vh;
  border: 0.2vh solid #ccc;
}
#toast {
  position: fixed;
  bottom: 5vh;
  left: 50%;
  transform: translateX(-50%);

  background: rgba(0, 0, 0, 0.8);
  color: white;
  padding: 1.5vh 3vw;
  border-radius: 1vh;

  opacity: 0;
  pointer-events: none;

  transition: opacity 0.3s;
}

#toast.show {
  opacity: 1;
}
    </style>
  </head>
<!-- HTML -->
  <body>
    <header>
      <h1>Generador de Colores 🎨</h1>
    </header>

    <main>
		<div id="toast">Copiado!</div>
<section class="card">
  <p>Colores actuales:</p>

  <div class="color-info">
	<span id="color1-text">Color 1: #667eea</span>
	<div id="color1-box" class="color-box"></div>
  </div>
  
  <div class="color-info">
	<span id="color2-text">Color 2: #764ba2</span>
	<div id="color2-box" class="color-box"></div>
  </div>
  <div class="button-group">
	<button id="btn-color1">Cambiar Color 1</button>
	<button id="btn-color2">Cambiar Color 2</button>
  </div>
</section>
    </main>

    <footer>
      <p>TP1 - Astro (el Juego)</p>
    </footer>
<!-- JavaScript -->
<script>
	document.addEventListener("DOMContentLoaded", () => {
	  let color1 = "#667eea";
	  let color2 = "#764ba2";
  
	  const toast = document.getElementById("toast");

	  const btn1 = document.getElementById("btn-color1");
	  const btn2 = document.getElementById("btn-color2");
  
	  const text1 = document.getElementById("color1-text");
	  const text2 = document.getElementById("color2-text");
  
	  const box1 = document.getElementById("color1-box");
	  const box2 = document.getElementById("color2-box");
  
	  function generarColor() {
		const letras = "0123456789ABCDEF";
		let color = "#";
  
		for (let i = 0; i < 6; i++) {
		  color += letras[Math.floor(Math.random() * 16)];
		}
  
		return color;
	  }
  
	  function actualizarFondo() {
		document.body.style.background =
		  "linear-gradient(135deg, " + color1 + ", " + color2 + ")";
	  }
  
	  function copiarColor(color) {
  navigator.clipboard.writeText(color);

  toast.textContent = "Copiado: " + color;
  toast.classList.add("show");

  setTimeout(() => {
    toast.classList.remove("show");
  }, 1500);
}
  
	  btn1.addEventListener("click", () => {
		color1 = generarColor();
		text1.textContent = "Color 1: " + color1;
		box1.style.backgroundColor = color1;
		actualizarFondo();
	  });
  
	  btn2.addEventListener("click", () => {
		color2 = generarColor();
		text2.textContent = "Color 2: " + color2;
		box2.style.backgroundColor = color2;
		actualizarFondo();
	  });
  
	  text1.addEventListener("click", () => copiarColor(color1));
	  text2.addEventListener("click", () => copiarColor(color2));
  
	  box1.addEventListener("click", () => copiarColor(color1));
	  box2.addEventListener("click", () => copiarColor(color2));
  
	  box1.style.backgroundColor = color1;
	  box2.style.backgroundColor = color2;
	});
  </script>
  </body>
</html>