    <title>Generador de Colores</title>

    <style>
body {
  font-family: Arial, sans-serif;
  margin: 0;
  text-align: center;

  min-height: 100vh;
  display: flex;
  flex-direction: column;

  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #333;
}

header {
  background: transparent;
  color: white;
  padding: 3vh;
}

main {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 5vh 5vw;
}

.card {
  background: white;
  padding: 4vh 4vw;
  border-radius: 2vh;

  width: 90%;
  max-width: 400px;

  box-shadow: 0 0.5vh 2vh rgba(0,0,0,0.2);
  transition: transform 0.2s;
}

.card:hover {
  transform: scale(1.03);
}

button {
  padding: 2vh 3vw;
  font-size: 1rem;

  border: none;
  border-radius: 1vh;

  background: linear-gradient(135deg, #00c6ff, #0072ff);
  color: white;

  cursor: pointer;
  transition: transform 0.2s, opacity 0.2s;

  width: 100%;
}

button:hover {
  transform: scale(1.05);
  opacity: 0.9;
}

.button-group {
  display: flex;
  flex-direction: column;
  gap: 2vh;
  margin-top: 3vh;
}

